{
  "info": {
    "name": "AttendanceKit API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}"},
            "header": [{"key": "Content-Type", "value": "application/json"}]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}]
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/attendances",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Check In",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/attendances/check-in",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"latitude\": -6.200000,\n  \"longitude\": 106.816666,\n  \"address\": \"Central Office\"\n}"}
          }
        },
        {
          "name": "Check Out",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/attendances/check-out",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}]
          }
        }
      ]
    }
  ]
}
